<!DOCTYPE html>
<html lang="ko">
<head>
    <script type="text/javascript" src="https://dapi.kakao.com/v2/maps/sdk.js?appkey=<%= kakaoKey %>&autoload=false&libraries=services"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>서울 혼잡도</title>
    <style>
        body, html { margin: 0; padding: 0; height: 100%; width: 100%; font-family: 'Pretendard', sans-serif; overflow: hidden; }
        #map { width: 100%; height: 100%; position: absolute; top: 0; left: 0; z-index: 1; }

        .ui-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 2;
            pointer-events: none; /* 지도가 클릭되도록 설정 */
            padding: 20px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* 내부에 들어가는 검색창과 리스트는 다시 클릭 가능하게 설정 */
        .search-container, #recommendationList {
            pointer-events: auto;
        }
    </style>
</head>

<body>
    <div id="map"></div>

    <div class="ui-overlay">
        <div class="search-container">
            <label for="locationModeSelect" style="font-size: 0.8rem;">검색 방식 선택</label>
            <select id="locationModeSelect">
                <option value="auto" selected>현재 위치 사용</option>
                <option value="manual">장소 검색</option>
            </select>

            <div id="manualLocationRow" class="manual-location hidden">
                <p style="font-size: 0.9rem; color: #666; margin-bottom: 10px;">검색 위치 주변 장소를 찾습니다.</p>
                <label for="distanceSelect" style="font-size: 0.8rem;">검색</label>
                <input id="manualLocationInput" type="text" inputmode="text" placeholder="주소/장소명">
                <button id="manualLocationApplyBtn" type="button" class="recommend-btn">검색</button>
            </div>
            
            
            <div id="autoLocationFields">
                <p style="font-size: 0.9rem; color: #666; margin-bottom: 10px;">현 위치 기반 장소를 찾습니다.</p>
                <label for="distanceSelect" style="font-size: 0.8rem;">검색 반경 설정</label>
                <select id="distanceSelect">
                    <option value="1">1km 이내</option>
                    <option value="5" selected>5km 이내</option>
                    <option value="10">10km 이내</option>
                    <option value="20">20km 이내</option>
                    <option value="30">30km 이내</option>
                    <option value="40">40km 이내</option>
                </select>
                <select id="congestionSelect">
                <option value="여유" selected>여유로운 곳</option>
                <option value="보통">보통인 곳</option>
                <option value="약간 붐빔">약간 붐비는 곳</option>
                </select>
                <button id="recommendBtn">추천받기</button>
            </div>

            
        </div>

        

        <div id="recommendationList">
            </div>
    </div>

    <div id="detailPanel" class="detail-panel hidden">
        <div class="drag-handle"></div>
        <div class="detail-header">
            <h2 id="detailTitle">장소명 정보</h2>
            <button id="closeDetailBtn" type="button">&times;</button>
        </div>
        
        <div class="detail-body">
            <div style="margin-bottom: 15px;">
                <p id="detailCongestion" style="font-weight: bold; margin: 5px 0;">혼잡도: 로딩 중...</p>
                <p id="detailDistance" style="color: #666; margin: 5px 0;">거리: 계산 중...</p>
            </div>

            <div class="action-grid">
                <button class="action-btn" id="findRouteBtn">📍 <span>길찾기</span></button>
                <button class="action-btn" id="savePlaceBtn">⭐ <span>장소 저장</span></button>
                <button class="action-btn" id="boardTabBtn">📝 <span>게시판 수정필요</span></button>
            </div>

            <hr style="border: 0; height: 1px; background: #eee; margin: 20px 0;">

            <div class="detail-tabs">
                <button class="tab-btn active" data-target="tab-recommend">주변 추천</button>
                <button class="tab-btn" data-target="tab-board">게시판</button>
            </div>

            <div id="tab-recommend" class="tab-content active">
                <div id="detailNearbyList">주변의 다른 추천 장소들이 여기에 표시됩니다.</div>
            </div>
            
            <div id="tab-board" class="tab-content">
                <div id="detailBoardContent">이 장소에 대한 방문자 리뷰 및 게시글이 표시됩니다.</div>
            </div>
        </div>
    </div>

    <script type="module" src="/js/main.js"></script>
    <script>
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-btn, .tab-content').forEach(el => el.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById(btn.dataset.target).classList.add('active');
            });
        });
    </script>
</body>
</html>